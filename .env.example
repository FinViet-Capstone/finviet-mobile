# Backend base URL (no trailing slash)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Firebase — get from google-services.json / GoogleService-Info.plist
EXPO_PUBLIC_FCM_SENDER_ID=

# Cloudinary (for avatar/photo uploads if handled client-side)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# FinVerse API (for linked wallet integration)
EXPO_PUBLIC_FINVERSE_API_URL=https://api.finverse.com/v1
EXPO_PUBLIC_FINVERSE_CLIENT_ID=
EXPO_PUBLIC_FINVERSE_CLIENT_SECRET=
