# Toggle the mock service layer. "true" until the .NET API ships.
EXPO_PUBLIC_USE_MOCK=true

# Backend base URL (no trailing slash)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Firebase — get from google-services.json / GoogleService-Info.plist
EXPO_PUBLIC_FCM_SENDER_ID=

# Cloudinary (for avatar/photo uploads if handled client-side)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# SePay API (for linked wallet integration) — static API token, no OAuth
EXPO_PUBLIC_SEPAY_API_URL=https://my.sepay.vn/userapi
EXPO_PUBLIC_SEPAY_API_TOKEN=
